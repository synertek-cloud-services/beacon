name = "beacon"
main = "src/index.ts"
compatibility_date = "2026-07-09"

# Custom domain route for production. Remove this block to use the default
# *.workers.dev subdomain instead.
[[routes]]
pattern = "your-api-domain.example.com"
custom_domain = true

[vars]
ALLOWED_ORIGIN = "https://your-dashboard-domain.example.com"
PAGES_PREVIEW_SUFFIX = ".your-pages-project.pages.dev"

[[d1_databases]]
binding = "DB"
database_name = "beacon"
database_id = "your-d1-database-id"
migrations_dir = "../migrations"

[triggers]
crons = ["*/2 * * * *"]

[[durable_objects.bindings]]
name = "SESSION"
class_name = "SessionRelay"

[[migrations]]
tag = "v1"
new_sqlite_classes = ["SessionRelay"]
