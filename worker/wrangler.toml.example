name = "beacon"
main = "src/index.ts"
compatibility_date = "2026-07-09"

# Custom domain route for production. Remove this block to use the default
# *.workers.dev subdomain instead.
[[routes]]
pattern = "your-api-domain.example.com"
custom_domain = true

[vars]
ALLOWED_ORIGIN = "https://your-dashboard-domain.example.com"
PAGES_PREVIEW_SUFFIX = ".your-pages-project.pages.dev"
# This worker's own public origin — must match the [[routes]] pattern above
# (with a scheme). Used to build absolute agent/client WebSocket URLs for
# remote sessions; kept as an explicit var rather than derived from the
# incoming request so it can't be misdirected by routing/proxy config.
WORKER_URL = "https://your-api-domain.example.com"

[[d1_databases]]
binding = "DB"
database_name = "beacon"
database_id = "your-d1-database-id"
migrations_dir = "../migrations"

[triggers]
crons = ["*/2 * * * *"]

[[durable_objects.bindings]]
name = "SESSION"
class_name = "SessionRelay"

[[migrations]]
tag = "v1"
new_sqlite_classes = ["SessionRelay"]

# Secrets (set via `wrangler secret put <NAME>`, not declared here):
#   ADMIN_SECRET          — break-glass bootstrap/recovery bearer token
#   CONFIG_ENCRYPTION_KEY — 32 random bytes hex (e.g. `openssl rand -hex 32`),
#                           encrypts SSO provider client secrets at rest
